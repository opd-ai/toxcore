# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out
coverage.txt

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env
api_fix_demo
noise_demo
main
*_test

# Example binaries and generated files
examples/*/toxav_*
examples/*/main
examples/*/*.exe
examples/tor_transport_demo/tor_transport_demo
examples/av_quality_monitor/av_quality_monitor
examples/file_transfer_demo/file_transfer_demo
refactored.json

# Root-level demo binaries
example
vp8_codec_demo
async_demo
audio_streaming_demo
toxav_basic_call
toxav_call_control_demo

# capi binary
capi/capi

# Testnet binaries and logs
testnet/toxtest
testnet/testnet
testnet/*.log
testnet/*.err*.test

# Transport private keys (auto-generated at runtime, must not be committed)
transport/onionkeys/
transport/i2pkeys/

